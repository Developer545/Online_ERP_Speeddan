# ══════════════════════════════════════════════════════════
# Speeddansys License Server — Variables de Entorno
# Copia este archivo a .env y ajusta los valores
# ══════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ──────────────────────────────
# Opción A: Neon cloud (producción)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Opción B: PostgreSQL local (desarrollo)
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=123321
# DB_NAME=speeddansys_licenses
# DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=cambiar-en-produccion-con-valor-aleatorio-largo

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.speeddansys.com

# ── Servidor ──────────────────────────────────────────────
PORT=4000

# ── Email (nodemailer) ────────────────────────────────────
# Si no se configura, los emails de bienvenida se omiten silenciosamente
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@speeddansys.com
SMTP_PASS=tu-contraseña-de-aplicacion

# URL base del ERP (para construir el link de bienvenida en el email)
ERP_APP_URL=https://app.speeddansys.com

# ── Integración con ERP ───────────────────────────────────
# URL del servidor ERP (Render en producción, localhost en dev)
ERP_API_URL=https://tu-erp.onrender.com

# Clave compartida entre este panel y el ERP para el endpoint interno
# Debe coincidir con INTERNAL_API_KEY en el ERP
INTERNAL_API_KEY=clave-secreta-interna-cambiar-en-produccion
